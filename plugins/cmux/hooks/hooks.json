{
  "description": "cmux native Claude Code integration and worktree workspace setup",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Applications/cmux.app/Contents/Resources/bin/cmux claude-hook session-start"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Applications/cmux.app/Contents/Resources/bin/cmux claude-hook stop"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Applications/cmux.app/Contents/Resources/bin/cmux claude-hook notification"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "EnterWorktree",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/setup-workspace.sh"
          }
        ]
      }
    ]
  }
}
